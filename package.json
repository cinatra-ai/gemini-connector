{
  "name": "@cinatra-ai/gemini-connector",
  "version": "0.1.4",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "src",
    "!src/__tests__"
  ,
    "cinatra"],
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./register": "./src/register.ts",
    "./log-directory": "./src/log-directory.ts"
  },
  "types": "src/index.ts",
  "scripts": {
    "test": "vitest",
    "lint": "eslint . --no-inline-config"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@cinatra-ai/sdk-extensions": "*",
    "@cinatra-ai/sdk-ui": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    },
    "@cinatra-ai/sdk-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "typescript": "5.9.3"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "connector",
    "consumes": [],
    "vendor": {
      "key": "cinatra-ai",
      "name": "Cinatra"
    },
    "displayName": "Gemini",
    "dependencies": [],
    "serverEntry": "./register",
    "requestedHostPorts": [
      "capabilities",
      "ui"
    ],
    "sdkAbiRange": "^2",
    "providerConfigKey": "cinatra-google-gemini",
    "llmProvider": {
      "abiVersion": 1,
      "provider": "gemini",
      "capabilities": {
        "function_tools": true,
        "media_input": true,
        "native_mcp": { "status": "unsupported" }
      },
      "models": {
        "default": "gemini-3.5-flash",
        "allowed": ["gemini-3.5-flash"]
      }
    },
    "uiSurface": "schema-config",
    "configSchema": {
      "title": "Gemini",
      "description": "Connect a Google Gemini API key so Gemini-powered agents and workflows can run. The key is stored securely via the connection service.",
      "fields": [
        {
          "kind": "banner",
          "label": "Result",
          "variants": [
            { "name": "saved", "tone": "success", "message": "Gemini connection saved." },
            { "name": "cleared", "tone": "warning", "message": "Gemini connection cleared." },
            { "name": "error", "tone": "destructive", "message": "Something went wrong." }
          ]
        },
        {
          "kind": "status-probe",
          "label": "Connection",
          "actionId": "connectionStatus",
          "description": "Check whether a Gemini API key is configured."
        },
        {
          "kind": "secret",
          "key": "apiKey",
          "label": "Gemini API key",
          "description": "Create a key in Google AI Studio. Write-only — the stored value is never shown again."
        },
        {
          "kind": "named-action",
          "label": "Save connection",
          "actionId": "saveConnection"
        },
        {
          "kind": "named-action",
          "label": "Clear connection",
          "actionId": "clearConnection",
          "confirm": "Clear the stored Gemini connection?"
        }
      ],
      "tabs": [
        {
          "id": "help",
          "label": "Help",
          "fields": [
            {
              "kind": "advisory",
              "label": "Gemini setup",
              "tone": "info",
              "probeActionId": "connectionServiceReady",
              "whenReady": "API keys are stored securely via the connection service. Use the Setup tab to update or clear your Gemini API key.",
              "whenNotReady": "Configure the connection service first so Gemini API requests can authenticate. Once it is ready, create a key in Google AI Studio and paste it into the Setup tab's API key field, then click Save connection to store it — the key is never shown again.",
              "description": "Read-only setup guidance — nothing on this tab is saved."
            }
          ]
        }
      ]
    }
  }
}
